namespace baitap
{
   class Bai47
    {
        static void Main()
        {
            Console.OutputEncoding = System.Text.Encoding.UTF8;
            Console.InputEncoding = System.Text.Encoding.UTF8;

            Console.Write("Nhập tên SV1: ");
            string ten1 = Console.ReadLine();
            Console.Write("Nhập điểm Toán SV1: ");
            double toan1 = double.Parse(Console.ReadLine());
            Console.Write("Nhập điểm Lý SV1: ");
            double ly1 = double.Parse(Console.ReadLine());

            Console.Write("Nhập tên SV2: ");
            string ten2 = Console.ReadLine();
            Console.Write("Nhập điểm Toán SV2: ");
            double toan2 = double.Parse(Console.ReadLine());
            Console.Write("Nhập điểm Lý SV2: ");
            double ly2 = double.Parse(Console.ReadLine());

            int check;

            if (toan1 > toan2)
                check = 1;
            else if (toan1 < toan2)
                check = 2;
            else
            {
                if (ly1 > ly2)
                    check = 1;
                else if (ly1 < ly2)
                    check = 2;
                else
                    check = 0;
            }

            switch (check)
            {
                case 1:
                    Console.WriteLine("\nSinh viên được chọn:");
                    Console.WriteLine(ten1 + " - Toán: " + toan1 + ", Lý: " + ly1);
                    break;

                case 2:
                    Console.WriteLine("\nSinh viên được chọn:");
                    Console.WriteLine(ten2 + " - Toán: " + toan2 + ", Lý: " + ly2);
                    break;

                case 0:
                    Console.WriteLine("\nSinh viên được chọn:");
                    Console.WriteLine(ten1 + " - Toán: " + toan1 + ", Lý: " + ly1);
                    break;
            }
        }
    }
}
